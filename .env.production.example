# === SKYLIVE — PRODUCTION ENVIRONMENT ===
# Copy to .env.production and fill in values
# NEVER commit production secrets to version control

# App
NODE_ENV=production
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=your@email.com
FRONTEND_URL=https://yourdomain.com
PORT=3001

# Database
# NEVER use default credentials in production
DATABASE_URL=postgresql://skylive:CHANGE_ME@postgres:5432/skylive_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# JWT — CHANGE THESE (min 32 chars, use a cryptographically secure random generator)
# NEVER reuse staging secrets in production
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM_PRODUCTION
JWT_EXPIRATION=12h
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MINIMUM_PRODUCTION_REFRESH
JWT_REFRESH_EXPIRATION=7d

# Stripe — use LIVE keys for production only
# NEVER use test keys in production
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# AWS / Cloudflare R2
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=eu-west-3
S3_BUCKET=skylive-media

# Sentry (strongly recommended in production)
SENTRY_DSN=CHANGE_ME

# Frontend (Next.js build args)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_WS_URL=https://api.yourdomain.com
NEXT_PUBLIC_HLS_BASE=https://rtmp.yourdomain.com/hls
