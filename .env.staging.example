# === SKYLIVE — STAGING ENVIRONMENT ===
# Copy to .env.staging and fill in values

# App
NODE_ENV=staging
DOMAIN=staging.yourdomain.com
LETSENCRYPT_EMAIL=your@email.com
FRONTEND_URL=https://staging.yourdomain.com
PORT=3001

# Database
DATABASE_URL=postgresql://skylive:CHANGE_ME@postgres:5432/skylive_db_staging

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — CHANGE THESE (min 32 chars)
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM_STAGING
JWT_EXPIRATION=12h
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MINIMUM_STAGING_REFRESH
JWT_REFRESH_EXPIRATION=7d

# Stripe — use test keys for staging
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# AWS / Cloudflare R2
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=eu-west-3
S3_BUCKET=skylive-media-staging

# Sentry (optional for staging)
SENTRY_DSN=

# Frontend (Next.js build args)
NEXT_PUBLIC_API_URL=https://api.staging.yourdomain.com/api
NEXT_PUBLIC_WS_URL=https://api.staging.yourdomain.com
NEXT_PUBLIC_HLS_BASE=https://rtmp.staging.yourdomain.com/hls
